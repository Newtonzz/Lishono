# Copy this file to .env.local and fill in values from your Supabase project settings.
# Settings -> API in the Supabase dashboard.
# In Expo, only variables prefixed with EXPO_PUBLIC_ are exposed to the app.
# The anon key is safe to ship to clients — Row Level Security protects your data.
# NEVER commit .env.local — it is gitignored.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
